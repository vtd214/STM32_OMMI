/* Includes ------------------------------------------------------------------*/
#include "main.h"
#include "tim.h"
#include "gpio.h"

/* Private includes ----------------------------------------------------------*/
/* USER CODE BEGIN Includes */
#include <stdint.h>
/* USER CODE END Includes */

/* Private typedef -----------------------------------------------------------*/
/* USER CODE BEGIN PTD */

/* USER CODE END PTD */

/* Private define ------------------------------------------------------------*/
/* USER CODE BEGIN PD */

/*
  MOTOR 3:
    LPWM -> PA2 -> TIM9_CH1
    RPWM -> PA3 -> TIM9_CH2
    EN   -> PC15 -> GPIO Output
*/

#define MOTOR3_LPWM_HTIM      htim9
#define MOTOR3_LPWM_CHANNEL   TIM_CHANNEL_1

#define MOTOR3_RPWM_HTIM      htim9
#define MOTOR3_RPWM_CHANNEL   TIM_CHANNEL_2

#define MOTOR3_EN_PORT        GPIOC
#define MOTOR3_EN_PIN         GPIO_PIN_15

/*
  Neu Counter Period = 999:
    300 = 30%
    600 = 60%
    900 = 90%
*/

#define PWM_LOW               300
#define PWM_MEDIUM            600
#define PWM_HIGH              900

/* USER CODE END PD */

/* Private macro -------------------------------------------------------------*/
/* USER CODE BEGIN PM */

/* USER CODE END PM */

/* Private variables ---------------------------------------------------------*/

/* USER CODE BEGIN PV */

volatile int debug_motor3_pwm = 0;
volatile int debug_motor3_state = 0;

/* USER CODE END PV */

/* Private function prototypes -----------------------------------------------*/
void SystemClock_Config(void);

/* USER CODE BEGIN PFP */

void Motor3_PWM_Init(void);
void Motor3_Enable(void);
void Motor3_Disable(void);
void Motor3_SetPWM(int pwm);
void Motor3_Stop(void);

/* USER CODE END PFP */

/* Private user code ---------------------------------------------------------*/
/* USER CODE BEGIN 0 */

void Motor3_PWM_Init(void)
{
  /*
    Start PWM:
      PA2 = TIM9_CH1
      PA3 = TIM9_CH2
  */
  HAL_TIM_PWM_Start(&MOTOR3_LPWM_HTIM, MOTOR3_LPWM_CHANNEL);
  HAL_TIM_PWM_Start(&MOTOR3_RPWM_HTIM, MOTOR3_RPWM_CHANNEL);

  Motor3_Enable();
  Motor3_Stop();
}

void Motor3_Enable(void)
{
  HAL_GPIO_WritePin(MOTOR3_EN_PORT, MOTOR3_EN_PIN, GPIO_PIN_SET);
}

void Motor3_Disable(void)
{
  HAL_GPIO_WritePin(MOTOR3_EN_PORT, MOTOR3_EN_PIN, GPIO_PIN_RESET);
}

void Motor3_SetPWM(int pwm)
{
  uint32_t pwm_max = __HAL_TIM_GET_AUTORELOAD(&MOTOR3_LPWM_HTIM);

  if (pwm > (int)pwm_max)
  {
    pwm = pwm_max;
  }

  if (pwm < -(int)pwm_max)
  {
    pwm = -pwm_max;
  }

  Motor3_Enable();

  debug_motor3_pwm = pwm;

  if (pwm > 0)
  {
    /*
      Quay thuan:
      LPWM co PWM
      RPWM = 0
    */
    __HAL_TIM_SET_COMPARE(&MOTOR3_LPWM_HTIM, MOTOR3_LPWM_CHANNEL, pwm);
    __HAL_TIM_SET_COMPARE(&MOTOR3_RPWM_HTIM, MOTOR3_RPWM_CHANNEL, 0);
  }
  else if (pwm < 0)
  {
    /*
      Quay nguoc:
      LPWM = 0
      RPWM co PWM
    */
    __HAL_TIM_SET_COMPARE(&MOTOR3_LPWM_HTIM, MOTOR3_LPWM_CHANNEL, 0);
    __HAL_TIM_SET_COMPARE(&MOTOR3_RPWM_HTIM, MOTOR3_RPWM_CHANNEL, -pwm);
  }
  else
  {
    Motor3_Stop();
  }
}

void Motor3_Stop(void)
{
  /*
    Stop an toan:
    LPWM = 0
    RPWM = 0
    Tat EN de tranh BTS7960 ham cung motor
  */
  __HAL_TIM_SET_COMPARE(&MOTOR3_LPWM_HTIM, MOTOR3_LPWM_CHANNEL, 0);
  __HAL_TIM_SET_COMPARE(&MOTOR3_RPWM_HTIM, MOTOR3_RPWM_CHANNEL, 0);

  debug_motor3_pwm = 0;

  Motor3_Disable();
}

/* USER CODE END 0 */

/**
  * @brief  The application entry point.
  * @retval int
  */
int main(void)
{
  /* USER CODE BEGIN 1 */

  /* USER CODE END 1 */

  HAL_Init();

  /* USER CODE BEGIN Init */

  /* USER CODE END Init */

  SystemClock_Config();

  /* USER CODE BEGIN SysInit */

  /* USER CODE END SysInit */

  MX_GPIO_Init();
  MX_TIM9_Init();

  /* USER CODE BEGIN 2 */

  Motor3_PWM_Init();

  /* USER CODE END 2 */

  /* Infinite loop */
  /* USER CODE BEGIN WHILE */

  while (1)
  {
    /* USER CODE END WHILE */

    /* USER CODE BEGIN 3 */

    /*
      Pha 1: PWM 300 - quay thuan cham
    */
    debug_motor3_state = 1;
    Motor3_SetPWM(PWM_LOW);
    HAL_Delay(3000);

    /*
      Dung
    */
    debug_motor3_state = 2;
    Motor3_Stop();
    HAL_Delay(1000);

    /*
      Pha 2: PWM 600 - quay thuan nhanh hon
    */
    debug_motor3_state = 3;
    Motor3_SetPWM(PWM_MEDIUM);
    HAL_Delay(3000);

    /*
      Dung
    */
    debug_motor3_state = 4;
    Motor3_Stop();
    HAL_Delay(1000);

    /*
      Pha 3: PWM 900 - quay thuan nhanh hon nua
    */
    debug_motor3_state = 5;
    Motor3_SetPWM(PWM_HIGH);
    HAL_Delay(3000);

    /*
      Dung
    */
    debug_motor3_state = 6;
    Motor3_Stop();
    HAL_Delay(1000);

    /*
      Pha 4: PWM am - quay nguoc
    */
    debug_motor3_state = 7;
    Motor3_SetPWM(-PWM_MEDIUM);
    HAL_Delay(3000);

    /*
      Dung
    */
    debug_motor3_state = 8;
    Motor3_Stop();
    HAL_Delay(2000);

    /* USER CODE END 3 */
  }
}

